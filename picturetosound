		~targetBinauralEarDelay = f[\texture].linlin(0, 1, 0.00032, 0.00125);
		~targetBinauralLevel = f[\brightness].linlin(0, 1, 0.82, 1.02);
		~targetTempo = f[\texture].linlin(0, 1, 0.86, 1.18)
			* f[\brightness].linlin(0, 1, 0.92, 1.08);
		if(~tagMode == \minor) {
