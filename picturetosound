/*
Visual Ambient System
SuperCollider patch for image- and text-reactive generative ambient music.

How to perform:
1. Open this file in SuperCollider.
2. Update ~imageFolder below if you want to use a different folder.
3. Evaluate the whole file.
4. Drop .jpg, .jpeg, .png, .tif, .tiff, or .bmp images into the folder.
5. Enter painting tags in the small text window, such as:
   cloudy romantic landscape

The music slowly re-tunes itself to each new image and text tag set.
*/

(
s.waitForBoot {
	~imageFolder = "/Users/beneyes/Documents/Codex/2026-06-12/create-a-generative-music-system-in/incoming_images";
	~presetFolder = "/Users/beneyes/Documents/Codex/2026-06-12/create-a-generative-music-system-in/outputs/presets";
	~pollSeconds = 1.0;

	~exts = Set["jpg", "jpeg", "png", "tif", "tiff", "bmp"];
	~seenImages = Set.new;
	~lastFeatures = (
		brightness: 0.5,
		saturation: 0.25,
		contrast: 0.25,
		warmth: 0.5,
		texture: 0.2,
		red: 0.5,
		green: 0.5,
		blue: 0.5,
		h1: 0.5,
		h2: 0.35,
		h3: 0.25,
		h4: 0.2,
		h5: 0.15,
		h6: 0.12
	);
	~tagText = "";
	~tagAmount = 0.0;
	~tagMode = \auto;
	~tagFeatures = ~lastFeatures.copy;
	~musicFeatures = ~lastFeatures.copy;

	~announce = { |text| ("[visual ambient] " ++ text).postln };

	~asColor = { |pixel|
		var int, red, green, blue, alpha;
		if(pixel.isKindOf(Color)) {
			pixel
		} {
			int = pixel.asInteger;
			alpha = ((int >> 24) & 255) / 255;
			red = ((int >> 16) & 255) / 255;
			green = ((int >> 8) & 255) / 255;
			blue = (int & 255) / 255;
			Color(red, green, blue, alpha)
		}
	};

	~pixelAt = { |image, x, y|
		var pixel, point;
		pixel = nil;
		point = Point(x, y);
		if(image.respondsTo(\getPixel)) {
			try {
				pixel = image.perform(\getPixel, x, y);
			} {
				try { pixel = image.perform(\getPixel, point) } { };
			};
		};
		if(pixel.isNil and: { image.respondsTo(\colorAt) }) {
			try {
				pixel = image.perform(\colorAt, x, y);
			} {
				try { pixel = image.perform(\colorAt, point) } { };
			};
		};
		if(pixel.isNil and: { image.respondsTo(\pixelAt) }) {
			try {
				pixel = image.perform(\pixelAt, x, y);
			} {
				try { pixel = image.perform(\pixelAt, point) } { };
			};
		};
		if(pixel.isNil) {
			Color(0.5, 0.5, 0.5)
		} {
			~asColor.(pixel)
		}
	};

	~blendFeatures = { |imageFeatures, tagFeatures, amount|
		var out = imageFeatures.copy;
		[\brightness, \saturation, \contrast, \warmth, \texture, \red, \green, \blue].do { |key|
			out[key] = ((imageFeatures[key] * (1 - amount)) + (tagFeatures[key] * amount)).clip(0, 1);
		};
		[\h1, \h2, \h3, \h4, \h5, \h6].do { |key|
			out[key] = imageFeatures[key].clip(0, 1);
		};
		out
	};

	~textHas = { |text, fragments|
		fragments.any { |fragment| text.find(fragment).notNil }
	};

	~featuresForTags = { |text|
		var lower, f;
		lower = text.asString.toLower;
		f = (
			brightness: 0.5,
			saturation: 0.3,
			contrast: 0.25,
			warmth: 0.5,
			texture: 0.25,
			red: 0.5,
			green: 0.5,
			blue: 0.5,
			h1: 0.5,
			h2: 0.35,
			h3: 0.25,
			h4: 0.2,
			h5: 0.15,
			h6: 0.12
		);
		~tagMode = \auto;

		if(~textHas.(lower, ["cloud", "mist", "fog", "grey", "gray", "overcast"])) {
			f[\brightness] = f[\brightness] - 0.18;
			f[\saturation] = f[\saturation] - 0.1;
			f[\contrast] = f[\contrast] - 0.08;
			f[\texture] = f[\texture] + 0.12;
			f[\blue] = f[\blue] + 0.2;
			~tagMode = \minor;
		};
		if(~textHas.(lower, ["romantic", "tender", "intimate", "lyric", "love"])) {
			f[\brightness] = f[\brightness] + 0.1;
			f[\saturation] = f[\saturation] + 0.25;
			f[\warmth] = f[\warmth] + 0.28;
			f[\red] = f[\red] + 0.22;
			f[\contrast] = f[\contrast] - 0.03;
			~tagMode = \lydian;
		};
		if(~textHas.(lower, ["landscape", "pastoral", "field", "hill", "forest", "garden", "river", "sea"])) {
			f[\brightness] = f[\brightness] + 0.12;
			f[\saturation] = f[\saturation] + 0.12;
			f[\texture] = f[\texture] - 0.04;
			f[\green] = f[\green] + 0.25;
			~tagMode = \major;
		};
		if(~textHas.(lower, ["night", "nocturne", "dark", "shadow", "moon"])) {
			f[\brightness] = f[\brightness] - 0.25;
			f[\contrast] = f[\contrast] + 0.08;
			f[\blue] = f[\blue] + 0.25;
			~tagMode = \minor;
		};
		if(~textHas.(lower, ["storm", "violent", "dramatic", "tempest", "battle"])) {
			f[\contrast] = f[\contrast] + 0.3;
			f[\texture] = f[\texture] + 0.32;
			f[\brightness] = f[\brightness] - 0.05;
			~tagMode = \minor;
		};
		if(~textHas.(lower, ["sun", "gold", "bright", "morning", "joy", "spring"])) {
			f[\brightness] = f[\brightness] + 0.28;
			f[\saturation] = f[\saturation] + 0.18;
			f[\warmth] = f[\warmth] + 0.22;
			f[\red] = f[\red] + 0.14;
			f[\green] = f[\green] + 0.1;
			~tagMode = \major;
		};
		if(~textHas.(lower, ["abstract", "cubist", "fragment", "modern", "geometric"])) {
			f[\contrast] = f[\contrast] + 0.18;
			f[\texture] = f[\texture] + 0.3;
			f[\saturation] = f[\saturation] + 0.12;
			~tagMode = \lydian;
		};
		if(~textHas.(lower, ["portrait", "figure", "face", "body", "human"])) {
			f[\warmth] = f[\warmth] + 0.16;
			f[\red] = f[\red] + 0.12;
			f[\contrast] = f[\contrast] + 0.04;
		};
		if(~textHas.(lower, ["sacred", "spiritual", "icon", "angel", "church", "cathedral"])) {
			f[\brightness] = f[\brightness] + 0.16;
			f[\saturation] = f[\saturation] + 0.08;
			f[\texture] = f[\texture] - 0.08;
			~tagMode = \lydian;
		};

		[\brightness, \saturation, \contrast, \warmth, \texture, \red, \green, \blue].do { |key|
			f[key] = f[key].clip(0, 1);
		};
		f
	};

	~openImage = { |path|
		var image;
		image = nil;
		try {
			if(Image.respondsTo(\open)) {
				image = Image.perform(\open, path);
			};
			if(image.isNil) {
				image = Image.new(path);
			};
		} { |error|
			("[visual ambient] Could not open image: " ++ path).warn;
			error.reportError;
		};
		image
	};

	~analyzeImage = { |path|
		var image, width, height, grid, samples;
		var red, green, blue, lum, lum2, sat, texture, harmonicSeeds;
		var prevLum, count, features;

		image = ~openImage.(path);
		if(image.isNil) {
			nil
		} {
			width = image.width.asInteger.max(1);
			height = image.height.asInteger.max(1);
			grid = 18;
			samples = Array.fill(grid * grid, { |i|
				var gx, gy, x, y, color, luma, maxc, minc;
				gx = i % grid;
				gy = (i / grid).floor;
				x = ((gx + 0.5) / grid * (width - 1)).asInteger.clip(0, width - 1);
				y = ((gy + 0.5) / grid * (height - 1)).asInteger.clip(0, height - 1);
				color = ~pixelAt.(image, x, y);
				luma = (color.red * 0.2126) + (color.green * 0.7152) + (color.blue * 0.0722);
				maxc = [color.red, color.green, color.blue].maxItem;
				minc = [color.red, color.green, color.blue].minItem;
				[color.red, color.green, color.blue, luma, maxc - minc]
			});

			red = samples.collect({ |v| v[0] }).mean;
			green = samples.collect({ |v| v[1] }).mean;
			blue = samples.collect({ |v| v[2] }).mean;
			lum = samples.collect({ |v| v[3] }).mean;
			lum2 = samples.collect({ |v| v[3].squared }).mean;
			sat = samples.collect({ |v| v[4] }).mean;
			texture = 0;
			prevLum = samples[0][3];
			count = 0;
			samples.do { |v|
				texture = texture + (v[3] - prevLum).abs;
				prevLum = v[3];
				count = count + 1;
			};
			texture = (texture / count.max(1)).clip(0, 1);
			harmonicSeeds = Array.fill(6, { |i|
				var sample, colorWeight;
				sample = samples.wrapAt((i * 43) + (width % 17) + (height % 19));
				colorWeight = [sample[0], sample[1], sample[2]].wrapAt(i);
				((sample[3] * 0.65) + (colorWeight * 0.35)).clip(0.03, 1)
			});

			features = (
				brightness: lum.clip(0, 1),
				saturation: sat.clip(0, 1),
				contrast: (lum2 - lum.squared).max(0).sqrt.linlin(0, 0.5, 0, 1).clip(0, 1),
				warmth: ((red - blue) * 0.5 + 0.5).clip(0, 1),
				texture: texture.linlin(0, 0.4, 0, 1).clip(0, 1),
				red: red.clip(0, 1),
				green: green.clip(0, 1),
				blue: blue.clip(0, 1),
				h1: harmonicSeeds[0],
				h2: harmonicSeeds[1],
				h3: harmonicSeeds[2],
				h4: harmonicSeeds[3],
				h5: harmonicSeeds[4],
				h6: harmonicSeeds[5]
			);

			if(image.respondsTo(\free)) { image.free };
			features
		}
	};

	SynthDef(\sh101Voice, { |out = 0, directOut = 0, freq = 110, amp = 0.1, sustain = 1.2, pan = 0,
		cutoff = 1200, resonance = 0.35, envAmt = 1800, pulseWidth = 0.5, accent = 0.3, glide = 0.04,
		directAmp = 0.28, attack = 0.01, decay = 0.35, release = 0.45, drift = 0.18, driftRate = 0.07,
		waveMorph = 0.5, harmonyMix = 0.18, filterMode = 0, filterDrive = 0.25, cutoffLfoDepth = 0.12, cutoffLfoRate = 0.04,
		cutoffSHDepth = 0.0, cutoffSHRate = 0.035, cutoffSHChance = 0.0,
		h1 = 0.5, h2 = 0.35, h3 = 0.25, h4 = 0.2, h5 = 0.15, h6 = 0.12|
		var env, filterEnv, rq, square, saw, sine, osc, sub, noise, harmony, sig, driven, filtered, stereo;
		var slidFreq, driftCents, driftRatio, cutoffMove, cutoffStep, cutoffStepGate, effectiveCutoff, low, high, notch;
		driftCents = SinOsc.kr(driftRate.clip(0.01, 0.35), Rand(0, 2pi)).range(drift.neg, drift);
		driftCents = driftCents + LFNoise2.kr(driftRate.clip(0.01, 0.35) * 0.7).range(drift.neg * 0.45, drift * 0.45);
		driftRatio = (driftCents / 1200).midiratio;
		slidFreq = Lag.kr(freq, glide) * driftRatio;
		env = EnvGen.kr(Env([0, 1, 0.62, 0], [attack.clip(0.005, 4), decay.clip(0.03, 8), release.clip(0.03, 12)], [-3, -4, -5]), doneAction: 2);
		filterEnv = EnvGen.kr(Env([0, 1, 0], [attack.clip(0.005, 4), decay.clip(0.03, 8) + (release.clip(0.03, 12) * 0.35)], [-3, -4]));
		square = Pulse.ar(slidFreq, pulseWidth.clip(0.08, 0.92));
		saw = Saw.ar(slidFreq);
		sine = SinOsc.ar(slidFreq);
		osc = SelectX.ar(waveMorph.clip(0, 2), [square, saw, sine]);
		osc = osc + (SelectX.ar(waveMorph.clip(0, 2), [
			Pulse.ar(slidFreq * 1.001, pulseWidth.clip(0.08, 0.92)),
			Saw.ar(slidFreq * 0.999),
			SinOsc.ar(slidFreq * 1.001)
		]) * 0.18);
		harmony = SinOsc.ar(slidFreq * [1.25, 1.333, 1.5, 1.667, 2, 2.5], 0,
			[h1.clip(0, 1), h2.clip(0, 1), h3.clip(0, 1), h4.clip(0, 1), h5.clip(0, 1), h6.clip(0, 1)] * 0.08).sum;
		sub = Pulse.ar(slidFreq * 0.5, 0.5) * 0.32;
		noise = PinkNoise.ar(0.018 * accent);
		rq = resonance.linlin(0, 1, 0.82, 0.16).clip(0.12, 0.92);
		sig = (osc * 0.58) + sub + (harmony * harmonyMix.clip(0, 0.85)) + noise;
		cutoffMove = SinOsc.kr(cutoffLfoRate.clip(0.005, 0.45), Rand(0, 2pi)).range(cutoffLfoDepth.neg, cutoffLfoDepth);
		cutoffStepGate = Latch.kr(WhiteNoise.kr.abs < cutoffSHChance.clip(0, 1), Impulse.kr(cutoffSHRate.clip(0.008, 0.16))).lag(4);
		cutoffStep = Latch.kr(WhiteNoise.kr, Impulse.kr(cutoffSHRate.clip(0.008, 0.16))).range(cutoffSHDepth.neg, cutoffSHDepth) * cutoffStepGate;
		effectiveCutoff = ((cutoff * (2 ** (cutoffMove + cutoffStep))) + (filterEnv * envAmt * (0.2 + (accent * 0.55)))).clip(45, 15000);
		driven = tanh(sig * (1.0 + (filterDrive.clip(0, 1) * 2.4) + (accent * 0.55)));
		low = RLPF.ar(driven, effectiveCutoff, rq);
		high = RHPF.ar(driven, effectiveCutoff, rq);
		notch = BRF.ar(driven, effectiveCutoff, rq);
		sig = Select.ar(filterMode.clip(0, 2), [low, high, notch]);
		sig = tanh(sig * (1.05 + (accent * 0.55)));
		stereo = Pan2.ar(sig * env * amp * (0.65 + accent), pan);
		Out.ar(out, stereo);
		Out.ar(directOut, stereo * directAmp);
	}).add;

	SynthDef(\ambisonicSpatialFx, { |in = 0, out = 0,
		grainMix = 0.0, grainSize = 0.14, grainPitch = 0.0, grainPitchDisp = 0.0, grainTimeDisp = 0.0,
		autoPanMix = 0.35, autoPanDepth = 0.45, autoPanSpeed = 0.08, autoPanShape = 0.0,
		ambiAngle = 0, ambiRotateRate = 0.025, ambiRotateDepth = 0.65, ambiElevation = 0,
		mix = 0.45, delay = 0.55, feedback = 0.38, wow = 0.25, tone = 3600, drive = 1.2|
		var dry, shifted, grain, sig, shapeIndex, panLfo, pan, panned, mono;
		var angle, rotate, elev, w, x, y, z, encoded, local, delayDrift, delayed, wet;
		dry = In.ar(in, 2);
		shifted = PitchShift.ar(
			dry,
			grainSize.clip(0.02, 0.6),
			grainPitch.clip(-24, 24).midiratio,
			grainPitchDisp.clip(0, 1.0),
			grainTimeDisp.clip(0, 1.0)
		);
		grain = LeakDC.ar(shifted);
		sig = XFade2.ar(dry, grain, grainMix.linlin(0, 1, -1, 1).clip(-1, 1));
		shapeIndex = autoPanShape.clip(0, 1) * 2;
		panLfo = SelectX.kr(shapeIndex, [
			SinOsc.kr(autoPanSpeed.clip(0.01, 8)),
			LFTri.kr(autoPanSpeed.clip(0.01, 8)),
			LFPulse.kr(autoPanSpeed.clip(0.01, 8)).range(-1, 1)
		]);
		pan = panLfo * autoPanDepth.clip(0, 1);
		panned = Pan2.ar(sig.sum * 0.5, pan);
		sig = XFade2.ar(sig, panned, autoPanMix.linlin(0, 1, -1, 1).clip(-1, 1));
		mono = sig.sum * 0.5;

		rotate = LFSaw.kr(ambiRotateRate.clip(0.001, 1.2)).range(pi.neg, pi) * ambiRotateDepth.clip(0, 1);
		angle = (ambiAngle.clip(-180, 180) * pi / 180) + rotate + (pan * pi);
		elev = ambiElevation.clip(-1, 1) * (pi * 0.5);
		w = mono * 0.707;
		x = mono * angle.cos * elev.cos;
		y = mono * angle.sin * elev.cos;
		z = mono * elev.sin;
		encoded = [w, x, y, z];

		local = LocalIn.ar(4);
		delayDrift = (SinOsc.kr([0.11, 0.13, 0.17, 0.19]).range(-0.018, 0.018)
			+ LFNoise2.kr(0.5 ! 4).range(-0.008, 0.008)) * wow;
		delayed = DelayC.ar(encoded + (local * feedback.clip(0, 0.92)), 1.8, (delay + delayDrift).clip(0.04, 1.75));
		delayed = tanh(delayed * drive.clip(0.5, 2.6));
		delayed = LPF.ar(HPF.ar(delayed, 60), tone.clip(500, 9500));
		LocalOut.ar(delayed);
		wet = XFade2.ar(encoded, delayed, mix.linlin(0, 1, -1, 1).clip(-1, 1));
		Out.ar(out, LeakDC.ar(wet));
	}).add;

	SynthDef(\binauralDecode, { |in = 0, out = 0, width = 0.78, earDelay = 0.00055, level = 0.9|
		var b, w, x, y, z, sideLate, height, left, right;
		b = In.ar(in, 4);
		w = b[0];
		x = b[1];
		y = b[2];
		z = b[3];
		sideLate = DelayC.ar(y, 0.012, earDelay.clip(0, 0.01));
		height = BPF.ar(z, 1800, 0.8) * 0.18;
		left = (w * 0.72) + (x * 0.42) + (y * width.clip(0, 1.4) * 0.56) + (sideLate * 0.24) + height;
		right = (w * 0.72) + (x * 0.42) - (y * width.clip(0, 1.4) * 0.56) - (sideLate * 0.24) - height;
		Out.ar(out, Limiter.ar(LeakDC.ar([left, right]) * level.clip(0, 1.4), 0.95));
	}).add;

	SynthDef(\stringDrone, { |out = 0, freq = 110, amp = 0.035, gate = 1,
		brightness = 0.5, texture = 0.25, warmth = 0.5, drift = 2.0|
		var trig, excite, ratios, freqs, coef, decay, driftRatio, strings, env, sig;
		ratios = [1, 1.5, 2, 2.01];
		driftRatio = SinOsc.kr([0.021, 0.027, 0.033, 0.041]).range(drift.neg, drift);
		driftRatio = (driftRatio / 1200).midiratio;
		freqs = (freq * ratios * driftRatio).clip(35, 5000);
		trig = Dust.kr(texture.linlin(0, 1, 0.08, 0.55) ! 4);
		excite = PinkNoise.ar(0.18 ! 4) * Decay2.kr(trig, 0.01, texture.linlin(0, 1, 1.8, 0.45));
		coef = warmth.linlin(0, 1, 0.28, 0.72);
		decay = brightness.linlin(0, 1, 9, 22);
		strings = Pluck.ar(excite, trig, 0.08, freqs.reciprocal, decay, coef);
		sig = Splay.ar(strings, 0.7);
		sig = LPF.ar(sig, brightness.linexp(0, 1, 900, 6200));
		env = EnvGen.kr(Env.asr(8, 1, 12), gate, doneAction: 2);
		Out.ar(out, sig * env * amp);
	}).add;

	s.sync;

	~synthBus = Bus.audio(s, 2);
	~ambiBus = Bus.audio(s, 4);
	~grainPan = Synth.tail(s, \ambisonicSpatialFx, [\in, ~synthBus.index, \out, ~ambiBus.index]);
	~binaural = Synth.tail(s, \binauralDecode, [\in, ~ambiBus.index, \out, 0]);
	~drone = Synth.tail(s, \stringDrone, [\out, 0]);
	~controlUpdater = {
		var f = ~musicFeatures, image = ~lastFeatures;
		~cutoff = image[\brightness].linexp(0, 1, 85, 9800)
			* image[\saturation].linlin(0, 1, 0.58, 1.34)
			* f[\warmth].linlin(0, 1, 0.92, 1.12);
		~resonance = image[\contrast].linlin(0, 1, 0.12, 0.62)
			+ f[\texture].linlin(0, 1, 0, 0.08);
		~envAmt = f[\texture].linexp(0, 1, 420, 2850);
		~pulseWidth = f[\warmth].linlin(0, 1, 0.28, 0.72);
		~targetAttack = image[\saturation].linexp(0, 1, 0.025, 1.85)
			* f[\brightness].linlin(0, 1, 1.2, 0.72)
			* f[\texture].linlin(0, 1, 1.1, 0.78);
		~targetDecay = f[\contrast].linlin(0, 1, 1.8, 0.24) * f[\saturation].linlin(0, 1, 1.15, 0.75);
		~targetRelease = f[\blue].linlin(0, 1, 0.35, 3.6)
			* image[\saturation].linlin(0, 1, 0.82, 1.45)
			* f[\brightness].linlin(0, 1, 1.25, 0.82);
		~targetDrift = f[\texture].linlin(0, 1, 1.8, 8.5) * f[\contrast].linlin(0, 1, 0.75, 1.4);
		~targetDriftRate = f[\brightness].linlin(0, 1, 0.035, 0.12);
		~targetNoteDur = f[\texture].linlin(0, 1, 1.75, 0.48) * f[\brightness].linlin(0, 1, 1.22, 0.82);
		~targetDelayFeedback = f[\saturation].linlin(0, 1, 0.22, 0.62)
			+ f[\contrast].linlin(0, 1, -0.04, 0.08)
			+ f[\blue].linlin(0, 1, 0.0, 0.08);
		~targetWaveMorph = f[\warmth].linlin(0, 1, 0.15, 1.75)
			+ f[\brightness].linlin(0, 1, -0.15, 0.25)
			- f[\contrast].linlin(0, 1, 0, 0.25);
		~targetHarmonyMix = f[\saturation].linlin(0, 1, 0.08, 0.48)
			+ f[\texture].linlin(0, 1, 0, 0.18);
		~targetFilterDrive = f[\contrast].linlin(0, 1, 0.08, 0.46)
			+ f[\saturation].linlin(0, 1, 0, 0.1);
		~targetCutoffLfoDepth = f[\texture].linlin(0, 1, 0.05, 0.42)
			+ f[\blue].linlin(0, 1, 0, 0.12);
		~targetCutoffLfoRate = f[\brightness].linlin(0, 1, 0.018, 0.09)
			+ f[\texture].linlin(0, 1, 0, 0.055);
		~targetCutoffSHDepth = f[\texture].linlin(0, 1, 0.0, 0.48)
			+ f[\contrast].linlin(0, 1, 0, 0.18);
		~targetCutoffSHRate = f[\brightness].linlin(0, 1, 0.018, 0.055)
