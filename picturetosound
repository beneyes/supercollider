	~scaleForFeatures = {
		var f = ~musicFeatures, root, scale;
		root = f[\warmth].linlin(0, 1, 38, 50).round(1);
		scale = if(~tagMode == \minor) {
			[0, 3, 5, 7, 10]
		} {
			if(~tagMode == \major) {
				[0, 2, 4, 7, 9]
			} {
				if(~tagMode == \lydian) {
					[0, 2, 4, 6, 7, 9, 11]
				} {
					if(f[\saturation] > 0.45) {
						[0, 2, 4, 6, 7, 9, 11]
					} {
						if(f[\brightness] < 0.35) { [0, 3, 5, 7, 10] } { [0, 2, 4, 7, 9] }
					}
				}
			}
		};
		[root, scale]
	};

	~makeMotif = {
		var f = ~musicFeatures, contour, lift, turn;
		contour = if(~tagMode == \minor) {
			[0, 1, 2, 3, 2, 1, 0, 1]
		} {
			if(~tagMode == \lydian) {
				[0, 2, 4, 6, 5, 4, 2, 1]
			} {
				if(f[\brightness] > 0.58) {
					[0, 2, 4, 5, 4, 2, 1, 0]
				} {
					if(f[\warmth] > 0.55) {
						[0, 1, 3, 4, 5, 4, 2, 1]
					} {
						[0, 1, 2, 4, 2, 1, 0, 1]
					}
				}
			}
		};
		lift = f[\saturation].linlin(0, 1, 0, 3).round(1).asInteger;
		turn = f[\texture].linlin(0, 1, 0, 2).round(1).asInteger;
		contour.collect { |degree, i|
			degree + (if((i + turn) % 4 == 0) { lift } { 0 })
		}
	};

	~degreeToSemitone = { |degree, scale|
		var size, safeDegree, octave, index;
		size = scale.size.max(1);
		safeDegree = degree.asInteger.max(0);
		octave = (safeDegree / size).floor;
		index = safeDegree % size;
		scale.wrapAt(index) + (12 * octave)
	};

	~updateDroneKey = {
		var scaleInfo, root, f;
		if(~drone.notNil) {
			f = ~musicFeatures;
			scaleInfo = ~scaleForFeatures.();
			root = scaleInfo[0];
			~drone.set(
				\freq, (root + 12).midicps,
				\brightness, f[\brightness],
				\texture, f[\texture],
				\warmth, f[\warmth],
				\drift, ~drift,
				\amp, f[\brightness].linlin(0, 1, 0.022, 0.045)
			);
		};
	};

	~rebuildMusicState = {
		~musicFeatures = ~blendFeatures.(~lastFeatures, ~tagFeatures, ~tagAmount);
		~currentMotif = ~makeMotif.();
		~randomOrder = (0 .. (~currentMotif.size - 1)).scramble;
		~pseudoOrder = (0 .. (~currentMotif.size - 1)).scramble;
		~controlUpdater.();
		~updateDroneKey.();
	};

	~applyTags = { |text|
		~tagText = text.asString;
		~tagAmount = if(~tagText.size > 0) { 0.72 } { 0.0 };
		~tagFeatures = ~featuresForTags.(~tagText);
		~rebuildMusicState.();
		~announce.("tags: " ++ if(~tagText.size > 0) { ~tagText } { "(cleared)" }
			++ " | mode " ++ ~tagMode
			++ " | brightness " ++ ~musicFeatures[\brightness].round(0.01)
			++ " | saturation " ++ ~musicFeatures[\saturation].round(0.01)
			++ " | texture " ++ ~musicFeatures[\texture].round(0.01)
			++ " | env " ++ ~targetAttack.round(0.01) ++ "/"
			++ ~targetDecay.round(0.01) ++ "/"
			++ ~targetRelease.round(0.01)
			++ " | drift " ++ ~targetDrift.round(0.1)
			++ " | noteDur " ++ ~targetNoteDur.round(0.01)
			++ " | feedback " ++ ~targetDelayFeedback.round(0.01)
