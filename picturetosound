		~release = (~release * 0.95) + (~targetRelease * 0.05);
		~drift = (~drift * 0.94) + (~targetDrift * 0.06);
		~driftRate = (~driftRate * 0.94) + (~targetDriftRate * 0.06);
		~noteDur = (~noteDur * 0.9) + (~targetNoteDur * 0.1);
		~delayFeedback = (~delayFeedback * 0.92) + (~targetDelayFeedback * 0.08);
		~waveMorph = (~waveMorph * 0.94) + (~targetWaveMorph * 0.06);
		~wavePhase = ~wavePhase + ~musicFeatures[\texture].linlin(0, 1, 0.018, 0.055);
		~voiceWaveMorph = (~waveMorph + (~wavePhase.sin * ~musicFeatures[\contrast].linlin(0, 1, 0.12, 0.42))).clip(0, 2);
		~harmonyMix = (~harmonyMix * 0.9) + (~targetHarmonyMix * 0.1);
		~filterDrive = (~filterDrive * 0.9) + (~targetFilterDrive * 0.1);
		~cutoffLfoDepth = (~cutoffLfoDepth * 0.92) + (~targetCutoffLfoDepth * 0.08);
		~cutoffLfoRate = (~cutoffLfoRate * 0.94) + (~targetCutoffLfoRate * 0.06);
		~cutoffSHDepth = (~cutoffSHDepth * 0.94) + (~targetCutoffSHDepth * 0.06);
		~cutoffSHRate = (~cutoffSHRate * 0.96) + (~targetCutoffSHRate * 0.04);
		~cutoffSHChance = (~cutoffSHChance * 0.95) + (~targetCutoffSHChance * 0.05);
		~grainMix = (~grainMix * 0.92) + (~targetGrainMix * 0.08);
		~grainSize = (~grainSize * 0.94) + (~targetGrainSize * 0.06);
		~grainPitch = (~grainPitch * 0.94) + (~targetGrainPitch * 0.06);
		~grainPitchDisp = (~grainPitchDisp * 0.92) + (~targetGrainPitchDisp * 0.08);
		~grainTimeDisp = (~grainTimeDisp * 0.92) + (~targetGrainTimeDisp * 0.08);
		~autoPanMix = (~autoPanMix * 0.94) + (~targetAutoPanMix * 0.06);
		~autoPanDepth = (~autoPanDepth * 0.94) + (~targetAutoPanDepth * 0.06);
		~autoPanSpeed = (~autoPanSpeed * 0.96) + (~targetAutoPanSpeed * 0.04);
		~autoPanShape = (~autoPanShape * 0.95) + (~targetAutoPanShape * 0.05);
		~ambiAngle = (~ambiAngle * 0.96) + (~targetAmbiAngle * 0.04);
