			\autoPanShape, ~autoPanShape,
			\ambiAngle, ~ambiAngle,
			\ambiRotateRate, ~ambiRotateRate,
			\ambiRotateDepth, ~ambiRotateDepth,
			\ambiElevation, ~ambiElevation,
			\mix, ~tapeMix,
			\delay, ~tapeDelayTime,
			\feedback, ~delayFeedback,
			\wow, ~tapeWow,
			\tone, ~tapeTone,
