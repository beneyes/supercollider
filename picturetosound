			value = text.asFloat;
			if(key == \filterMode) { value.asInteger } { value }
		}
	};

	~presetNameToPath = { |name|
		var safe;
		safe = name.asString.stripWhiteSpace;
		if(safe.size <= 0) { safe = "visual_ambient_preset" };
		safe = safe.replace(" ", "_").replace("/", "_").replace(":", "_");
		~presetFolder +/+ safe ++ ".txt"
	};

	~presetFiles = {
		if(File.exists(~presetFolder).not) {
			("mkdir -p " ++ ~presetFolder.quote).unixCmdGetStdOut;
		};
		PathName(~presetFolder).files.select { |path|
			path.extension.asString.toLower == "txt"
		}.sort { |a, b| a.fileName < b.fileName }
	};

	~refreshPresetMenu = {
		var files, names;
		if(~controlGui.notNil and: { ~controlGui[\presetMenu].notNil }) {
			files = ~presetFiles.();
			names = files.collect { |path| path.fileNameWithoutExtension };
			if(names.isEmpty) { names = ["(no presets saved)"] };
			{
				~controlGuiUpdating = true;
				~controlGui[\presetMenu].items = names;
				~controlGui[\presetMenu].value = 0;
				~controlGuiUpdating = false;
			}.defer;
		};
	};

