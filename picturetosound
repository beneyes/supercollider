		~ambiRotateDepth = (~ambiRotateDepth * 0.95) + (~targetAmbiRotateDepth * 0.05);
		~ambiElevation = (~ambiElevation * 0.96) + (~targetAmbiElevation * 0.04);
		~binauralWidth = (~binauralWidth * 0.96) + (~targetBinauralWidth * 0.04);
		~binauralEarDelay = (~binauralEarDelay * 0.96) + (~targetBinauralEarDelay * 0.04);
		~binauralLevel = (~binauralLevel * 0.96) + (~targetBinauralLevel * 0.04);
		~tempo = (~tempo * 0.985) + (~targetTempo * 0.015);
		~tempoPhase = ~tempoPhase + ~musicFeatures[\texture].linlin(0, 1, 0.004, 0.014);
		~tempoWander = (~tempo * (1 + (~tempoPhase.sin * ~musicFeatures[\contrast].linlin(0, 1, 0.015, 0.075)))).clip(0.55, 1.55);
		~grainPan.set(
			\grainMix, ~grainMix,
			\grainSize, ~grainSize,
			\grainPitch, ~grainPitch,
			\grainPitchDisp, ~grainPitchDisp,
			\grainTimeDisp, ~grainTimeDisp,
			\autoPanMix, ~autoPanMix,
			\autoPanDepth, ~autoPanDepth,
