	~chooseArpMode = {
		var f, weights;
		f = ~musicFeatures;
		weights = [
			f[\brightness].linlin(0, 1, 0.18, 0.28),
			f[\brightness].linlin(0, 1, 0.24, 0.12),
			f[\warmth].linlin(0, 1, 0.18, 0.3),
			f[\texture].linlin(0, 1, 0.08, 0.25),
			f[\contrast].linlin(0, 1, 0.1, 0.28)
		].normalizeSum;
		~arpMode = ~arpModes.wchoose(weights);
		~arpModeStep = 0;
		~arpDirection = 1;
		~randomOrder = (0 .. (~currentMotif.size - 1)).scramble;
		if(~arpMode == \pseudoRandom) {
			~pseudoOrder = (0 .. (~currentMotif.size - 1)).scramble;
		};
		~arpModeChangeEvery = ~musicFeatures[\texture].linlin(0, 1, 24, 8).round(1).asInteger.max(4);
		~announce.("arp order: " ++ ~arpMode);
	};

	~chooseArpSpeedMode = {
		var f, weights;
		f = ~musicFeatures;
		weights = [
			f[\brightness].linlin(0, 1, 0.24, 0.1),
			f[\brightness].linlin(0, 1, 0.22, 0.26),
			f[\texture].linlin(0, 1, 0.08, 0.28),
			f[\contrast].linlin(0, 1, 0.1, 0.28),
			(f[\texture] + f[\contrast]).linlin(0, 2, 0.1, 0.3)
		].normalizeSum;
		~arpSpeedMode = ~arpSpeedModes.wchoose(weights);
		~arpSpeedChangeEvery = f[\texture].linlin(0, 1, 20, 6).round(1).asInteger.max(4);
		~pseudoRhythmStep = 0;
		if(~arpSpeedMode == \pseudoRhythm) {
			~pseudoRhythmPattern = [0.5, 0.75, 1, 1.5, 2, 0.666, 1.333, 1].scramble;
		};
		~announce.("arp speed: " ++ ~arpSpeedMode);
	};

	~chooseFilterMode = {
		var f, weights, modes, choice;
		f = ~musicFeatures;
		modes = [[0, \lowpass], [1, \highpass], [2, \notch]];
		weights = [
			f[\brightness].linlin(0, 1, 0.62, 0.48),
			f[\texture].linlin(0, 1, 0.12, 0.28) + if(~tagMode == \minor) { 0.06 } { 0 },
			f[\contrast].linlin(0, 1, 0.1, 0.34)
		].normalizeSum;
		choice = modes.wchoose(weights);
		~filterMode = choice[0];
		~filterModeName = choice[1];
		~filterModeChangeEvery = f[\texture].linlin(0, 1, 28, 8).round(1).asInteger.max(6);
		~announce.("filter mode: " ++ ~filterModeName);
	};

	~arpSpeedMultiplier = {
		var multiplier, value;
		if((~arpStep > 0) and: { (~arpStep % ~arpSpeedChangeEvery) == 0 }) {
			~chooseArpSpeedMode.();
		};
		multiplier = if(~arpSpeedMode == \half) {
			2
		} {
			if(~arpSpeedMode == \double) {
				0.5
			} {
				if(~arpSpeedMode == \triplet) {
					2 / 3
				} {
					if(~arpSpeedMode == \pseudoRhythm) {
						value = ~pseudoRhythmPattern.wrapAt(~pseudoRhythmStep);
						~pseudoRhythmStep = ~pseudoRhythmStep + 1;
						value
					} {
						1
					}
				}
			}
		};
		multiplier
	};

	~nextArpIndex = {
		var size, index, maxIndex;
		size = ~currentMotif.size.max(1);
		maxIndex = (size - 1).max(1);
		if((~arpStep > 0) and: { (~arpStep % ~arpModeChangeEvery) == 0 }) {
			~chooseArpMode.();
		};
		index = if(~arpMode == \down) {
			size - 1 - (~arpModeStep % size)
		} {
			if(~arpMode == \pingpong) {
				if(~arpModeStep >= maxIndex) {
					~arpModeStep = 0;
					~arpDirection = ~arpDirection.neg;
				};
				if(~arpDirection > 0) { ~arpModeStep } { maxIndex - ~arpModeStep }
			} {
				if(~arpMode == \random) {
					size.rand
				} {
					if(~arpMode == \pseudoRandom) {
						if((~arpModeStep % size) == 0) {
							~pseudoOrder = (0 .. (size - 1)).scramble;
						};
						~pseudoOrder.wrapAt(~arpModeStep)
					} {
						~arpModeStep % size
					}
				}
			}
		};
		~arpModeStep = ~arpModeStep + 1;
		index.clip(0, size - 1)
	};

	~arpStep = 0;
	~playArpStep = {
		var f, scaleInfo, root, scale, degree, motifIndex, chordOffset, octave, midi, freq;
		var amp, pan, sustain, waitTime, accent, bassDegree, releaseDrift, followFreq;
		f = ~musicFeatures;
		if((~arpStep > 0) and: { (~arpStep % ~filterModeChangeEvery) == 0 }) {
			~chooseFilterMode.();
		};
		scaleInfo = ~scaleForFeatures.();
		~evolveEnvelope.();
		root = scaleInfo[0];
		scale = scaleInfo[1];
		motifIndex = ~nextArpIndex.();
		degree = ~currentMotif.wrapAt(motifIndex);
		chordOffset = [0, 2, 4, 7].wrapAt((motifIndex / 2).floor);
		octave = [12, 24, 24, 36].wrapAt(~arpStep) + if((~arpStep % 8) == 7) { 12 } { 0 };
		midi = root + octave + ~degreeToSemitone.(degree + chordOffset, scale);
		freq = midi.midicps;

		accent = if((~arpStep % 4) == 0) { 0.85 } { f[\contrast].linlin(0, 1, 0.2, 0.65) };
		amp = f[\brightness].linlin(0, 1, 0.085, 0.17);
		pan = f[\red].linlin(0, 1, -0.45, 0.45) + 0.12.rand2;
		sustain = ~noteDur;
		releaseDrift = ~release.linlin(0.08, 6.5, 0, 8).clip(0, 8);
		Synth(\sh101Voice, [
			\out, ~synthBus.index,
			\directOut, 0,
			\freq, freq,
			\amp, amp,
			\pan, pan.clip(-1, 1),
			\sustain, sustain,
			\cutoff, ~cutoff * (0.86 + (0.18 * (~arpStep % 4))),
			\resonance, (~resonance + (accent * 0.035)).clip(0, 1),
			\envAmt, ~envAmt,
			\pulseWidth, ~pulseWidth,
			\accent, accent,
			\glide, f[\warmth].linlin(0, 1, 0.015, 0.11),
			\directAmp, 0.42,
			\attack, ~attack,
			\decay, ~decay,
			\release, ~release,
			\drift, (~drift + releaseDrift).clip(0.2, 22),
			\driftRate, ~driftRate,
			\waveMorph, ~voiceWaveMorph,
			\harmonyMix, ~harmonyMix,
			\filterMode, ~filterMode,
			\filterDrive, ~filterDrive,
			\cutoffLfoDepth, ~cutoffLfoDepth,
			\cutoffLfoRate, ~cutoffLfoRate,
			\cutoffSHDepth, ~cutoffSHDepth,
			\cutoffSHRate, ~cutoffSHRate,
			\cutoffSHChance, ~cutoffSHChance,
			\h1, f[\h1],
			\h2, f[\h2],
			\h3, f[\h3],
			\h4, f[\h4],
			\h5, f[\h5],
			\h6, f[\h6]
		]);
		if(~arpPitchHistory.size >= 2) {
			followFreq = ~arpPitchHistory.wrapAt(~arpPitchHistory.size - 2);
			Synth(\sh101Voice, [
				\out, ~synthBus.index,
				\directOut, 0,
				\freq, followFreq,
				\amp, amp * 0.58,
				\pan, (pan.neg * 0.75).clip(-1, 1),
				\sustain, sustain * 1.08,
				\cutoff, (~cutoff * 0.78).clip(90, 9000),
				\resonance, (~resonance + 0.018).clip(0, 1),
				\envAmt, ~envAmt * 0.82,
				\pulseWidth, ~pulseWidth,
				\accent, accent * 0.55,
				\glide, f[\warmth].linlin(0, 1, 0.025, 0.14),
				\directAmp, 0.28,
				\attack, (~attack * 1.12).clip(0.01, 4),
				\decay, ~decay,
				\release, (~release * 1.2).clip(0.1, 9),
				\drift, (~drift + releaseDrift + 1.5).clip(0.2, 24),
				\driftRate, (~driftRate * 0.82).clip(0.01, 0.16),
				\waveMorph, (~voiceWaveMorph + 0.18).clip(0, 2),
				\harmonyMix, (~harmonyMix * 0.72).clip(0.02, 0.55),
				\filterMode, ~filterMode,
				\filterDrive, (~filterDrive * 0.82).clip(0.03, 0.8),
				\cutoffLfoDepth, (~cutoffLfoDepth * 0.9).clip(0.01, 0.58),
				\cutoffLfoRate, (~cutoffLfoRate * 0.86).clip(0.006, 0.16),
				\cutoffSHDepth, (~cutoffSHDepth * 0.82).clip(0, 0.62),
				\cutoffSHRate, (~cutoffSHRate * 0.92).clip(0.01, 0.08),
				\cutoffSHChance, (~cutoffSHChance * 0.86).clip(0.02, 0.55),
				\h1, f[\h1],
				\h2, f[\h2],
				\h3, f[\h3],
				\h4, f[\h4],
				\h5, f[\h5],
				\h6, f[\h6]
			]);
		};
		~arpPitchHistory.add(freq);
		while { ~arpPitchHistory.size > 16 } {
			~arpPitchHistory.removeAt(0);
		};

		if((~arpStep % 8) == 0) {
			bassDegree = [0, 3, 4].wchoose([0.62, 0.18, 0.2]);
			Synth(\sh101Voice, [
				\out, ~synthBus.index,
				\directOut, 0,
					\freq, (root + ~degreeToSemitone.(bassDegree, scale)).midicps,
					\amp, f[\brightness].linlin(0, 1, 0.065, 0.12),
					\pan, -0.05,
					\sustain, (~noteDur * 3.4).clip(1.2, 7),
				\cutoff, (~cutoff * 0.45).clip(90, 1800),
				\resonance, (~resonance * 0.72).clip(0, 1),
				\envAmt, ~envAmt * 0.55,
				\pulseWidth, ~pulseWidth,
				\accent, 0.42,
				\glide, 0.08,
				\directAmp, 0.35,
				\attack, (~attack * 1.4).clip(0.01, 3),
				\decay, (~decay * 1.35).clip(0.08, 6),
				\release, (~release * 1.7).clip(0.1, 9),
				\drift, ((~drift * 0.65) + (releaseDrift * 0.45)).clip(0.2, 12),
				\driftRate, (~driftRate * 0.7).clip(0.01, 0.14),
				\waveMorph, ~voiceWaveMorph,
				\harmonyMix, (~harmonyMix * 0.55).clip(0.02, 0.5),
				\filterMode, ~filterMode,
				\filterDrive, (~filterDrive * 0.72).clip(0.03, 0.7),
				\cutoffLfoDepth, (~cutoffLfoDepth * 0.65).clip(0.01, 0.42),
				\cutoffLfoRate, (~cutoffLfoRate * 0.75).clip(0.006, 0.14),
				\cutoffSHDepth, (~cutoffSHDepth * 0.58).clip(0, 0.46),
				\cutoffSHRate, (~cutoffSHRate * 0.78).clip(0.01, 0.07),
				\cutoffSHChance, (~cutoffSHChance * 0.68).clip(0.02, 0.42),
				\h1, f[\h1],
				\h2, f[\h2],
				\h3, f[\h3],
				\h4, f[\h4],
				\h5, f[\h5],
				\h6, f[\h6]
			]);
		};

		~arpStep = ~arpStep + 1;
			waitTime = (~noteDur * f[\texture].linlin(0, 1, 1.0, 0.75) * ~arpSpeedMultiplier.() / ~tempoWander).clip(0.14, 6.2);
			waitTime
	};

	~startArp = {
		if(~arpRoutine.notNil) { ~arpRoutine.stop };
		~chooseArpMode.();
		~chooseArpSpeedMode.();
		~chooseFilterMode.();
		~arpRoutine = Routine {
			~announce.("arpeggiator started");
			loop {
				~playArpStep.().wait;
			}
		}.play(TempoClock.default);
	};

	~stopArp = {
		if(~arpRoutine.notNil) {
			~arpRoutine.stop;
			~arpRoutine = nil;
			~announce.("arpeggiator stopped");
		};
	};

	~startArp.();

	~imageFiles = {
		var dir = PathName(~imageFolder);
		if(File.exists(~imageFolder).not) {
			~announce.("Creating image folder: " ++ ~imageFolder);
			("mkdir -p " ++ ~imageFolder).unixCmd;
		};
		PathName(~imageFolder).files.select { |path|
			~exts.includes(path.extension.asString.toLower)
		}.sort { |a, b| a.fileName < b.fileName }
	};

	~applyImage = { |path|
		var features;
		~announce.("reading " ++ path.fileName);
		features = ~analyzeImage.(path.fullPath);
		if(features.notNil) {
			~lastFeatures = features;
			~rebuildMusicState.();
			~announce.(
				"brightness " ++ features[\brightness].round(0.01)
				++ " | saturation " ++ features[\saturation].round(0.01)
				++ " | contrast " ++ features[\contrast].round(0.01)
				++ " | warmth " ++ features[\warmth].round(0.01)
				++ " | texture " ++ features[\texture].round(0.01)
				++ " | cutoff " ++ ~cutoff.round(1)
				++ " | resonance " ++ ~resonance.round(0.01)
				++ " | env " ++ ~targetAttack.round(0.01) ++ "/"
				++ ~targetDecay.round(0.01) ++ "/"
				++ ~targetRelease.round(0.01)
				++ " | drift " ++ ~targetDrift.round(0.1)
				++ " | noteDur " ++ ~targetNoteDur.round(0.01)
				++ " | feedback " ++ ~targetDelayFeedback.round(0.01)
				++ " | wave " ++ ~targetWaveMorph.round(0.01)
				++ " | harm " ++ ~targetHarmonyMix.round(0.01)
				++ " | filter " ++ ~filterModeName
				++ " | drive " ++ ~targetFilterDrive.round(0.01)
				++ " | lfo " ++ ~targetCutoffLfoDepth.round(0.01)
				++ " | s+h " ++ ~targetCutoffSHDepth.round(0.01)
				++ " | grain " ++ ~targetGrainMix.round(0.01)
				++ " | pan " ++ ~targetAutoPanDepth.round(0.01)
				++ " | ambi " ++ ~targetAmbiAngle.round(1) ++ "/"
