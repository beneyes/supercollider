	~watcher = Routine {
		~announce.("Drop images into: " ++ ~imageFolder);
		loop {
			~imageFiles.().do { |path|
				if(~seenImages.includes(path.fullPath).not) {
					~seenImages.add(path.fullPath);
					~applyImage.(path);
				};
			};
			~pollSeconds.wait;
		}
	}.play(AppClock);

	~makeControlWindow = {
		var window, y, sliders, makeSlider, modeMenu, speedMenu, filterMenu, presetMenu, presetNameField;
		var saveButton, loadButton, randomButton, refreshButton, rowHeight, valueWidth;
		try {
			rowHeight = 23;
			valueWidth = 58;
			sliders = IdentityDictionary.new;
			~controlGuiUpdating = false;
			window = Window("Visual Ambient Controls", Rect(760, 20, 540, 1080)).front;
			y = 10;

			StaticText(window, Rect(12, y, 496, 18)).string = "Live controls: image/tag analysis updates these values as the patch evolves";
			y = y + 28;

			StaticText(window, Rect(12, y + 3, 64, 18)).string = "preset";
			presetNameField = TextField(window, Rect(80, y, 118, 22));
			presetNameField.string = "visual_ambient_preset";
			saveButton = Button(window, Rect(204, y, 50, 22));
			saveButton.states = [["Save"]];
			loadButton = Button(window, Rect(260, y, 50, 22));
			loadButton.states = [["Load"]];
			randomButton = Button(window, Rect(316, y, 66, 22));
			randomButton.states = [["Random"]];
			refreshButton = Button(window, Rect(388, y, 62, 22));
			refreshButton.states = [["Refresh"]];
			presetMenu = PopUpMenu(window, Rect(456, y, 72, 22));
			presetMenu.items = ["(no presets saved)"];
			saveButton.action = { ~savePreset.(presetNameField.string) };
			loadButton.action = {
				var selected;
				selected = presetMenu.items.wrapAt(presetMenu.value);
				if(selected.notNil and: { selected != "(no presets saved)" }) {
					~loadPreset.(selected);
					presetNameField.string = selected;
				} {
					~loadPreset.(presetNameField.string);
				};
			};
			randomButton.action = { ~randomisePreset.() };
			refreshButton.action = { ~refreshPresetMenu.() };
			y = y + 30;

			makeSlider = { |key, label, min, max, step, getFunc, setFunc|
				var slider;
				slider = EZSlider(
					window,
					Rect(12, y, 516, 20),
					label,
					ControlSpec(min, max, \lin, step, getFunc.value),
					{ |view|
						if(~controlGuiUpdating.not) {
							setFunc.value(view.value);
						};
					},
					getFunc.value,
					false,
					145,
					valueWidth
				);
				sliders[key] = (view: slider, get: getFunc);
				y = y + rowHeight;
			};

			makeSlider.(\cutoff, "LP cutoff", 45, 15000, 1, { ~cutoff }, { |v| ~cutoff = v.clip(45, 15000) });
			makeSlider.(\resonance, "resonance", 0, 1, 0.001, { ~resonance }, { |v| ~resonance = v.clip(0, 1) });
			makeSlider.(\envAmt, "filter env", 0, 5000, 1, { ~envAmt }, { |v| ~envAmt = v.clip(0, 5000) });
			makeSlider.(\pulseWidth, "pulse width", 0.08, 0.92, 0.001, { ~pulseWidth }, { |v| ~pulseWidth = v.clip(0.08, 0.92) });
			makeSlider.(\attack, "attack target", 0.005, 4, 0.001, { ~targetAttack }, { |v| ~targetAttack = v.clip(0.005, 4) });
			makeSlider.(\decay, "decay target", 0.03, 8, 0.001, { ~targetDecay }, { |v| ~targetDecay = v.clip(0.03, 8) });
			makeSlider.(\release, "release target", 0.03, 12, 0.001, { ~targetRelease }, { |v| ~targetRelease = v.clip(0.03, 12) });
			makeSlider.(\drift, "pitch drift", 0, 24, 0.01, { ~targetDrift }, { |v| ~targetDrift = v.clip(0, 24) });
			makeSlider.(\driftRate, "drift rate", 0.005, 0.35, 0.001, { ~targetDriftRate }, { |v| ~targetDriftRate = v.clip(0.005, 0.35) });
			makeSlider.(\noteDur, "note duration", 0.14, 6.2, 0.001, { ~targetNoteDur }, { |v| ~targetNoteDur = v.clip(0.14, 6.2) });
			makeSlider.(\delayFeedback, "delay feedback", 0, 0.88, 0.001, { ~targetDelayFeedback }, { |v| ~targetDelayFeedback = v.clip(0, 0.88); ~delayFeedback = ~targetDelayFeedback; ~grainPan.set(\feedback, ~delayFeedback) });
			makeSlider.(\tapeMix, "delay mix", 0, 1, 0.001, { ~tapeMix }, { |v| ~tapeMix = v.clip(0, 1); ~grainPan.set(\mix, ~tapeMix) });
			makeSlider.(\tapeDelayTime, "delay time", 0.04, 1.55, 0.001, { ~tapeDelayTime }, { |v| ~tapeDelayTime = v.clip(0.04, 1.55); ~grainPan.set(\delay, ~tapeDelayTime) });
			makeSlider.(\tapeWow, "tape wow", 0, 0.9, 0.001, { ~tapeWow }, { |v| ~tapeWow = v.clip(0, 0.9); ~grainPan.set(\wow, ~tapeWow) });
			makeSlider.(\tapeTone, "delay tone", 500, 9000, 1, { ~tapeTone }, { |v| ~tapeTone = v.clip(500, 9000); ~grainPan.set(\tone, ~tapeTone) });
			makeSlider.(\tapeDrive, "delay drive", 0.6, 2.4, 0.001, { ~tapeDrive }, { |v| ~tapeDrive = v.clip(0.6, 2.4); ~grainPan.set(\drive, ~tapeDrive) });
			makeSlider.(\waveMorph, "wave morph", 0, 2, 0.001, { ~targetWaveMorph }, { |v| ~targetWaveMorph = v.clip(0, 2) });
			makeSlider.(\harmonyMix, "harmony mix", 0, 0.85, 0.001, { ~targetHarmonyMix }, { |v| ~targetHarmonyMix = v.clip(0, 0.85) });
			makeSlider.(\filterDrive, "filter drive", 0, 1, 0.001, { ~targetFilterDrive }, { |v| ~targetFilterDrive = v.clip(0, 1) });
			makeSlider.(\cutoffLfoDepth, "cutoff LFO depth", 0, 0.8, 0.001, { ~targetCutoffLfoDepth }, { |v| ~targetCutoffLfoDepth = v.clip(0, 0.8) });
			makeSlider.(\cutoffLfoRate, "cutoff LFO rate", 0.005, 0.25, 0.001, { ~targetCutoffLfoRate }, { |v| ~targetCutoffLfoRate = v.clip(0.005, 0.25) });
			makeSlider.(\cutoffSHDepth, "S+H cutoff depth", 0, 0.9, 0.001, { ~targetCutoffSHDepth }, { |v| ~targetCutoffSHDepth = v.clip(0, 0.9) });
			makeSlider.(\cutoffSHRate, "S+H cutoff rate", 0.008, 0.16, 0.001, { ~targetCutoffSHRate }, { |v| ~targetCutoffSHRate = v.clip(0.008, 0.16) });
			makeSlider.(\cutoffSHChance, "S+H chance", 0, 1, 0.001, { ~targetCutoffSHChance }, { |v| ~targetCutoffSHChance = v.clip(0, 1) });
			makeSlider.(\grainMix, "grain mix", 0, 1, 0.001, { ~targetGrainMix }, { |v| ~targetGrainMix = v.clip(0, 1) });
			makeSlider.(\grainSize, "grain size", 0.02, 0.6, 0.001, { ~targetGrainSize }, { |v| ~targetGrainSize = v.clip(0.02, 0.6) });
			makeSlider.(\grainPitch, "grain pitch", -24, 24, 0.001, { ~targetGrainPitch }, { |v| ~targetGrainPitch = v.clip(-24, 24) });
			makeSlider.(\grainPitchDisp, "grain pitch jitter", 0, 1, 0.001, { ~targetGrainPitchDisp }, { |v| ~targetGrainPitchDisp = v.clip(0, 1) });
			makeSlider.(\grainTimeDisp, "grain time jitter", 0, 1, 0.001, { ~targetGrainTimeDisp }, { |v| ~targetGrainTimeDisp = v.clip(0, 1) });
			makeSlider.(\autoPanMix, "auto-pan mix", 0, 1, 0.001, { ~targetAutoPanMix }, { |v| ~targetAutoPanMix = v.clip(0, 1) });
			makeSlider.(\autoPanDepth, "auto-pan depth", 0, 1, 0.001, { ~targetAutoPanDepth }, { |v| ~targetAutoPanDepth = v.clip(0, 1) });
			makeSlider.(\autoPanSpeed, "auto-pan speed", 0.01, 8, 0.001, { ~targetAutoPanSpeed }, { |v| ~targetAutoPanSpeed = v.clip(0.01, 8) });
			makeSlider.(\autoPanShape, "auto-pan shape", 0, 1, 0.001, { ~targetAutoPanShape }, { |v| ~targetAutoPanShape = v.clip(0, 1) });
			makeSlider.(\ambiAngle, "ambi angle", -180, 180, 0.001, { ~targetAmbiAngle }, { |v| ~targetAmbiAngle = v.clip(-180, 180) });
			makeSlider.(\ambiRotateRate, "ambi rotate rate", 0.001, 1.2, 0.001, { ~targetAmbiRotateRate }, { |v| ~targetAmbiRotateRate = v.clip(0.001, 1.2) });
			makeSlider.(\ambiRotateDepth, "ambi rotate depth", 0, 1, 0.001, { ~targetAmbiRotateDepth }, { |v| ~targetAmbiRotateDepth = v.clip(0, 1) });
			makeSlider.(\ambiElevation, "ambi elevation", -1, 1, 0.001, { ~targetAmbiElevation }, { |v| ~targetAmbiElevation = v.clip(-1, 1) });
			makeSlider.(\binauralWidth, "binaural width", 0, 1.4, 0.001, { ~targetBinauralWidth }, { |v| ~targetBinauralWidth = v.clip(0, 1.4) });
			makeSlider.(\binauralEarDelay, "binaural ear delay", 0, 0.01, 0.00001, { ~targetBinauralEarDelay }, { |v| ~targetBinauralEarDelay = v.clip(0, 0.01) });
			makeSlider.(\binauralLevel, "binaural level", 0, 1.4, 0.001, { ~targetBinauralLevel }, { |v| ~targetBinauralLevel = v.clip(0, 1.4) });
			makeSlider.(\tempo, "tempo target", 0.55, 1.55, 0.001, { ~targetTempo }, { |v| ~targetTempo = v.clip(0.55, 1.55) });
			makeSlider.(\droneAmp, "drone level", 0, 0.08, 0.001, { ~musicFeatures[\brightness].linlin(0, 1, 0.022, 0.045) }, { |v| if(~drone.notNil) { ~drone.set(\amp, v.clip(0, 0.08)) } });
			makeSlider.(\tagBlend, "tag blend", 0, 1, 0.001, { ~tagAmount }, { |v| ~tagAmount = v.clip(0, 1); ~rebuildMusicState.() });

			StaticText(window, Rect(12, y + 3, 145, 18)).string = "filter mode";
			filterMenu = PopUpMenu(window, Rect(160, y, 130, 22));
			filterMenu.items = ["lowpass", "highpass", "notch"];
			filterMenu.value = ~filterMode.clip(0, 2).asInteger;
			filterMenu.action = { |menu|
				if(~controlGuiUpdating.not) {
					~filterMode = menu.value;
					~filterModeName = [\lowpass, \highpass, \notch].wrapAt(~filterMode);
				};
			};
			y = y + rowHeight;

			StaticText(window, Rect(12, y + 3, 145, 18)).string = "arp order";
			modeMenu = PopUpMenu(window, Rect(160, y, 130, 22));
			modeMenu.items = ~arpModes.collect { |item| item.asString };
			modeMenu.value = ~arpModes.indexOf(~arpMode).max(0);
			modeMenu.action = { |menu|
				if(~controlGuiUpdating.not) {
					~arpMode = ~arpModes.wrapAt(menu.value);
					~arpModeStep = 0;
				};
			};
			y = y + rowHeight;

			StaticText(window, Rect(12, y + 3, 145, 18)).string = "arp speed";
			speedMenu = PopUpMenu(window, Rect(160, y, 130, 22));
			speedMenu.items = ~arpSpeedModes.collect { |item| item.asString };
			speedMenu.value = ~arpSpeedModes.indexOf(~arpSpeedMode).max(0);
			speedMenu.action = { |menu|
				if(~controlGuiUpdating.not) {
					~arpSpeedMode = ~arpSpeedModes.wrapAt(menu.value);
					~pseudoRhythmStep = 0;
				};
			};
			y = y + 36;

			Button(window, Rect(12, y, 90, 26)).states_([["Start arp"]]).action_({ ~startArp.() });
			Button(window, Rect(108, y, 90, 26)).states_([["Stop arp"]]).action_({ ~stopArp.() });
			Button(window, Rect(204, y, 90, 26)).states_([["Test note"]]).action_({ ~playTestNote.() });
			Button(window, Rect(300, y, 90, 26)).states_([["One step"]]).action_({ ~playArpStep.() });
			Button(window, Rect(396, y, 90, 26)).states_([["Rebuild"]]).action_({ ~rebuildMusicState.() });

			~controlGui = (
				window: window,
				sliders: sliders,
				filterMenu: filterMenu,
				modeMenu: modeMenu,
				speedMenu: speedMenu,
				presetMenu: presetMenu
			);
			window.onClose_({ ~controlGui = nil });
			~refreshPresetMenu.();
			~updateControlGui.();
		} {
			~announce.("Could not open control window.");
		};
	};

	~updateControlGui = {
		if(~controlGui.notNil) {
			{
				~controlGuiUpdating = true;
				~controlGui[\sliders].keysValuesDo { |key, spec|
					spec[\view].value = spec[\get].value;
				};
				~controlGui[\filterMenu].value = ~filterMode.clip(0, 2).asInteger;
				~controlGui[\modeMenu].value = ~arpModes.indexOf(~arpMode).max(0);
				~controlGui[\speedMenu].value = ~arpSpeedModes.indexOf(~arpSpeedMode).max(0);
				~controlGuiUpdating = false;
			}.defer;
		};
	};

	~controlGuiRoutine = Routine {
		loop {
			~updateControlGui.();
			0.35.wait;
		}
	}.play(AppClock);

	~makeTagWindow = {
		var window, field, applyButton, clearButton, label;
		try {
			window = Window("Painting Tags", Rect(220, 220, 520, 104)).front;
			label = StaticText(window, Rect(12, 10, 496, 18));
			label.string = "Enter painting tags, e.g. cloudy romantic landscape";
			field = TextField(window, Rect(12, 36, 340, 28));
			field.string = ~tagText;
			applyButton = Button(window, Rect(362, 36, 70, 28));
			applyButton.states = [["Apply"]];
			clearButton = Button(window, Rect(440, 36, 68, 28));
			clearButton.states = [["Clear"]];
			field.action = { ~applyTags.(field.string) };
			applyButton.action = { ~applyTags.(field.string) };
			clearButton.action = {
				field.string = "";
				~applyTags.("");
			};
			~tagWindow = window;
		} {
			~announce.("Could not open tag window. Use ~applyTags.(\"cloudy romantic landscape\") instead.");
		};
	};

	{
		~makeTagWindow.();
		~makeControlWindow.();
		~announce.("Enter tags in the window, or evaluate ~applyTags.(\"cloudy romantic landscape\").");
	}.defer;

	~stopVisualAmbient = {
		~watcher.stop;
		~stopArp.();
		if(~drone.notNil) { ~drone.set(\gate, 0) };
		if(~grainPan.notNil) { ~grainPan.free };
		if(~binaural.notNil) { ~binaural.free };
		if(~tagWindow.notNil) { ~tagWindow.close };
		if(~controlGuiRoutine.notNil) { ~controlGuiRoutine.stop };
		if(~controlGui.notNil) { ~controlGui[\window].close };
		"visual ambient system stopped".postln;
	};

	~announce.("running. Evaluate ~startArp.() to restart the arpeggiator, or ~stopVisualAmbient.() to stop.");
};
)
