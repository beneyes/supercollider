	~savePreset = { |name = "visual_ambient_preset"|
		var path, file;
		if(File.exists(~presetFolder).not) {
			("mkdir -p " ++ ~presetFolder.quote).unixCmdGetStdOut;
		};
		path = ~presetNameToPath.(name);
		file = File(path, "w");
		file.write("# Visual Ambient preset\n");
		file.write("# one key=value pair per line\n");
		~presetKeys.do { |key|
			file.write(key.asString ++ "=" ++ ~valueForPreset.(key).asString ++ "\n");
		};
		file.close;
		~announce.("saved preset: " ++ path);
		~refreshPresetMenu.();
		path
	};

	~loadPreset = { |nameOrPath|
		var path, file, lines, parts, key, value;
		path = if(nameOrPath.asString.endsWith(".txt")) {
			nameOrPath.asString
		} {
			~presetNameToPath.(nameOrPath)
		};
		if(File.exists(path).not) {
			~announce.("preset not found: " ++ path);
		} {
			file = File(path, "r");
			lines = file.readAllString.split($\n);
			file.close;
			lines.do { |line|
				if((line.size > 0) and: { line.beginsWith("#").not and: { line.includes($=) } }) {
					parts = line.split($=);
					key = parts[0].stripWhiteSpace.asSymbol;
					if(~presetKeys.includes(key)) {
						value = parts[1].stripWhiteSpace;
						currentEnvironment[key] = ~coercePresetValue.(key, value);
					};
				};
			};
			~pushRecalledControls.();
			~announce.("loaded preset: " ++ path);
		};
	};

