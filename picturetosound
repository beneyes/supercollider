			+ f[\contrast].linlin(0, 1, 0, 0.18);
		~targetAutoPanSpeed = f[\texture].linexp(0, 1, 0.025, 0.42)
			* f[\brightness].linlin(0, 1, 0.85, 1.2);
		~targetAutoPanShape = f[\contrast].linlin(0, 1, 0.0, 0.78);
		~targetAmbiAngle = (f[\red] - f[\blue]).linlin(-1, 1, -135, 135);
