			if(param == \reverb) { drumVoices[index][\reverb] = val };
			if(param == \delay) { drumVoices[index][\delay] = val };
			if(param == \drive) { drumVoices[index][\mixDrive] = val };
			if(param == \mute) { drumVoices[index][\muted] = (val > 0.5).asInteger };
			if(param == \solo) { drumVoices[index][\solo] = (val > 0.5).asInteger };
		} {
			if(index == drumVoices.size) {
				if(param == \level) { synthParams.put(\level, val) };
				if(param == \filter) { synthMixer.put(\mixFilter, val) };
				if(param == \reverb) { synthParams.put(\reverbSend, val) };
				if(param == \delay) { synthParams.put(\delaySend, val) };
				if(param == \drive) { synthMixer.put(\mixDrive, val) };
				if(param == \mute) { synthMixer.put(\muted, (val > 0.5).asInteger) };
				if(param == \solo) { synthMixer.put(\solo, (val > 0.5).asInteger) };
			} {
				if(index == (drumVoices.size + 1)) {
					if(param == \level) { sampleParams.put(\level, val) };
					if(param == \filter) { sampleMixer.put(\mixFilter, val) };
					if(param == \reverb) { sampleParams.put(\reverbSend, val) };
					if(param == \delay) { sampleParams.put(\delaySend, val) };
					if(param == \drive) { sampleMixer.put(\mixDrive, val) };
					if(param == \mute) { sampleMixer.put(\muted, (val > 0.5).asInteger) };
					if(param == \solo) { sampleMixer.put(\solo, (val > 0.5).asInteger) };
				};
			};
		};
		{
			if(refreshMixerGui.notNil) { refreshMixerGui.() };
			if(masterVolumeControl.notNil) {
				masterVolumeControl[\slider].value_(masterAmp.clip(0, 1));
				masterVolumeControl[\box].value_(masterAmp.round(0.01));
			};
		}.defer;
	};

	applyMidiLearnParam = { |param, value|
		if(param.notNil) {
			case
			{ param[0] == \presetNav } {
				var key, active;
				key = param.asCompileString;
				active = value > 0.5;
				if(active and: { (midiActionLatches[key] ? false).not }) {
					if(param[1] == \prev) { selectPresetOffset.(-1) };
					if(param[1] == \next) { selectPresetOffset.(1) };
				};
				midiActionLatches.put(key, active);
			}
			{ param[0] == \mixer } {
				setMixerChannel.(param[1].asInteger, param[2], value);
			}
			{ param[0] == \drumLevel } {
				drumVoices[param[1].asInteger][\level] = value;
				{ if(refreshMixerGui.notNil) { refreshMixerGui.() } }.defer;
			}
			{ param[0] == \drumParam } {
				var vi, key, spec, mapped, args;
				vi = param[1].asInteger;
				key = param[2];
				spec = drumParamSpec.(drumVoices[vi], key);
				mapped = value.linlin(0, 1, spec[0], spec[1]);
				if(key == \delay) {
					drumVoices[vi][\delay] = mapped;
				} {
					if(key == \reverb) {
						drumVoices[vi][\reverb] = mapped;
					} {
						if(key == \pan) {
							drumVoices[vi][\pan] = mapped;
						} {
							args = drumVoices[vi][\args].copy;
							args.put(key, mapped);
							drumVoices[vi][\args] = args;
						};
					};
				};
				{ refreshMachineGui.() }.defer;
			}
			{ param[0] == \sampleParam } {
				var spec, mapped;
				spec = sampleParamSpec[param[1]];
				mapped = value.linlin(0, 1, spec[0], spec[1]);
				sampleParams.put(param[1], mapped);
				{ refreshMachineGui.() }.defer;
			}
			{ param[0] == \synthParam } {
				synthParams.put(param[1], value);
				{ refreshMachineGui.() }.defer;
			}
			{ param[0] == \synthEnv } {
				var spec, mapped;
				spec = synthEnvSpec[param[1]];
				mapped = value.linlin(0, 1, spec[0], spec[1]);
				synthParams.put(param[1], mapped);
				{ refreshMachineGui.() }.defer;
			}
			{ param[0] == \synthLfo } {
				synthParams.put(param[1], value);
				{ refreshMachineGui.() }.defer;
			}
			{ param[0] == \fx } {
				var spec, mapped;
				spec = fxParamSpec[param[1]];
				mapped = value.linlin(0, 1, spec[0], spec[1]);
				fxParams.put(param[1], mapped);
				delaySynth.set(\time, fxParams[\delayTime], \feedback, fxParams[\delayFeedback], \wow, fxParams[\delayWow], \tone, fxParams[\delayTone], \wet, fxParams[\delayWet]);
				reverbSynth.set(\room, fxParams[\reverbRoom], \damp, fxParams[\reverbDamp], \wet, fxParams[\reverbWet], \shimmer, fxParams[\reverbShimmer]);
				{ refreshMachineGui.() }.defer;
			}
			{ param[0] == \masterComp } {
				masterCompParams.put(param[1], value);
				masterSynth.set(param[1], value);
				{ refreshMachineGui.() }.defer;
			}
			{ param[0] == \masterVolume } {
				masterAmp = value;
				masterSynth.set(\amp, masterAmp);
				{ refreshMachineGui.() }.defer;
			};
		};
	};

	applyMidiNoteParam = { |param, velocity, isOn=1|
		var value, index, mixerParam, current;
		value = (velocity.clip(0, 127) / 127).clip(0, 1);
		if(param.notNil) {
			if(param[0] == \presetNav) {
				applyMidiLearnParam.(param, if(isOn == 1) { 1 } { 0 });
			} {
				if(isOn == 1) {
					if((param[0] == \mixer) and: { (param[2] == \mute) or: { param[2] == \solo } }) {
						index = param[1].asInteger;
						mixerParam = param[2];
						current = 0;
						if(index < drumVoices.size) {
							current = if(mixerParam == \mute) { drumVoices[index][\muted] } { drumVoices[index][\solo] };
						} {
							if(index == drumVoices.size) {
								current = if(mixerParam == \mute) { synthMixer[\muted] } { synthMixer[\solo] };
							} {
								if(index == (drumVoices.size + 1)) {
									current = if(mixerParam == \mute) { sampleMixer[\muted] } { sampleMixer[\solo] };
								};
							};
						};
						setMixerChannel.(index, mixerParam, if(current.asInteger == 1) { 0 } { 1 });
					} {
						applyMidiLearnParam.(param, value);
					};
				};
			};
		};
	};

	setupMidiMix = {
		MIDIClient.init;
		MIDIIn.connectAll;
		loadMidiMappings.();
		midiMixVolumeCCs.do({ |cc, i| if(midiMappings[cc].isNil) { midiMappings.put(cc, [\mixer, i, \level]) } });
		midiMixFilterCCs.do({ |cc, i| if(midiMappings[cc].isNil) { midiMappings.put(cc, [\mixer, i, \filter]) } });
		midiMixReverbCCs.do({ |cc, i| if(midiMappings[cc].isNil) { midiMappings.put(cc, [\mixer, i, \reverb]) } });
		midiMixDelayCCs.do({ |cc, i| if(midiMappings[cc].isNil) { midiMappings.put(cc, [\mixer, i, \delay]) } });
		if(midiMappings[midiMixMasterCC].isNil) { midiMappings.put(midiMixMasterCC, [\mixer, drumVoices.size + 1, \level]) };
		if(midiMappings[midiMixWavFilterCC].isNil) { midiMappings.put(midiMixWavFilterCC, [\mixer, drumVoices.size + 1, \filter]) };
		if(midiMappings[midiMixWavReverbCC].isNil) { midiMappings.put(midiMixWavReverbCC, [\mixer, drumVoices.size + 1, \reverb]) };
		if(midiMappings[midiMixWavDelayCC].isNil) { midiMappings.put(midiMixWavDelayCC, [\mixer, drumVoices.size + 1, \delay]) };
		MIDIdef.cc(\groovebox_midi_learn_router, { |val, cc|
			if(midiLearnActive and: { midiLearnParam.notNil }) {
				midiMappings.put(cc, midiLearnParam.copy);
				saveMidiMappings.();
				midiLearnActive = false;
				midiLearnParam = nil;
				{
					if(midiLearnButton.notNil) {
						midiLearnButton.value_(0);
						midiLearnButton.states_([["LRN", colors[\text], colors[\panel2]], ["LRN", colors[\bg], colors[\yellow]]]);
					};
				}.defer;
			} {
				if(midiMappings[cc].notNil) {
					applyMidiLearnParam.(midiMappings[cc], val / 127);
				};
			};
		}, nil);
		MIDIdef.noteOn(\groovebox_midi_note_learn_router, { |vel, note|
			if(vel <= 0) {
				if(midiNoteMappings[note].notNil) {
					applyMidiNoteParam.(midiNoteMappings[note], 0, 0);
				};
			} {
				if(midiLearnActive and: { midiLearnParam.notNil }) {
					midiNoteMappings.put(note, midiLearnParam.copy);
					saveMidiMappings.();
					midiLearnActive = false;
					midiLearnParam = nil;
					{
						if(midiLearnButton.notNil) {
							midiLearnButton.value_(0);
							midiLearnButton.states_([["LRN", colors[\text], colors[\panel2]], ["LRN", colors[\bg], colors[\yellow]]]);
						};
					}.defer;
				} {
					if(midiNoteMappings[note].notNil) {
						applyMidiNoteParam.(midiNoteMappings[note], vel, 1);
					};
				};
			};
		}, nil);
		MIDIdef.noteOff(\groovebox_midi_note_off_router, { |vel, note|
			if(midiNoteMappings[note].notNil) {
				applyMidiNoteParam.(midiNoteMappings[note], 0, 0);
			};
		}, nil);
	};
	setupMidiMix.();

	OSCdef(\combined_groovebox_song_preset, { |msg|
		var name, state;
		name = msg[1].asString;
		("Main Groovebox received song preset request: " ++ name).postln;
		if(presets[name].isNil) {
			loadPresets.();
		};
		state = presets[name];
		if(state.notNil) {
			queuePreset.(state);
			("Main Groovebox queued preset: " ++ name).postln;
		} {
			("Main Groovebox could not find preset: " ++ name).postln;
		};
	}, '/combinedGroovebox/preset');
	("Main Groovebox song OSC receiver armed on language port " ++ NetAddr.langPort.asString ++ " path /combinedGroovebox/preset").postln;

	[
		win.view, root, transportView, drumView, drumEditView, synthSeqView, sampleView, synthView, fxView, mixerView,
		playButton, stopButton, randomDrumButton, randomSynthButton, randomWavButton, randomAllButton, presetPrevButton, presetNextButton, midiLearnButton, presetExportButton, presetImportButton, midiExportButton, midiImportButton, swingSlider, rootBox, presetMenu,
		drumDivMenu,
		synthKeyMenu, synthScaleMenu, synthDivMenu, synthLfoShapeMenu, synthLfoDestMenu,
		sampleFilterMenu, sampleDivMenu, delaySyncButton, delaySyncMenu
	].do({ |view|
		if(view.notNil) { view.keyDownAction_(handleSpaceKey) };
	});
	drumButtons.do({ |row| row.do({ |button| button.keyDownAction_(handleSpaceKey) }) });
	drumClearButtons.do({ |button| if(button.notNil) { button.keyDownAction_(handleSpaceKey) } });
	drumMuteButtons.do({ |button| if(button.notNil) { button.keyDownAction_(handleSpaceKey) } });
	drumLevelSliders.do({ |slider| if(slider.notNil) { slider.keyDownAction_(handleSpaceKey) } });
	drumVoiceButtons.do({ |button| button.keyDownAction_(handleSpaceKey) });
	drumParamRows.do({ |row|
		row[\row].keyDownAction_(handleSpaceKey);
		row[\slider].keyDownAction_(handleSpaceKey);
	});
	synthGateButtons.do({ |button| button.keyDownAction_(handleSpaceKey) });
	synthNoteSliders.do({ |slider| slider.keyDownAction_(handleSpaceKey) });
	synthAccentButtons.do({ |button| button.keyDownAction_(handleSpaceKey) });
	synthSlideButtons.do({ |button| button.keyDownAction_(handleSpaceKey) });
	sampleParamControls.do({ |control|
		control[\slider].keyDownAction_(handleSpaceKey);
	});
	sampleSliceSliders.do({ |slider| slider.keyDownAction_(handleSpaceKey) });
	synthParamControls.do({ |control|
		control[\slider].keyDownAction_(handleSpaceKey);
	});
	synthEnvControls.do({ |control|
		control[\slider].keyDownAction_(handleSpaceKey);
	});
	synthLfoControls.do({ |control|
		control[\row].keyDownAction_(handleSpaceKey);
		control[\slider].keyDownAction_(handleSpaceKey);
	});
	fxParamControls.do({ |control|
		control[\slider].keyDownAction_(handleSpaceKey);
	});
	mixerRows.do({ |row|
		row[\row].keyDownAction_(handleSpaceKey);
		row[\level].keyDownAction_(handleSpaceKey);
		row[\filter].keyDownAction_(handleSpaceKey);
		row[\drive].keyDownAction_(handleSpaceKey);
		row[\mute].keyDownAction_(handleSpaceKey);
		row[\solo].keyDownAction_(handleSpaceKey);
	});
	masterCompControls.do({ |control|
		control[\slider].keyDownAction_(handleSpaceKey);
	});
	masterVolumeControl[\slider].keyDownAction_(handleSpaceKey);

	win.onClose_({
		task.notNil.if({ task.stop });
		sampleBuf.notNil.if({ sampleBuf.free });
		midiMixVolumeCCs.do({ |cc, i| MIDIdef(("midimix_vol_" ++ i.asString).asSymbol).free });
		midiMixFilterCCs.do({ |cc, i| MIDIdef(("midimix_filter_" ++ i.asString).asSymbol).free });
		midiMixReverbCCs.do({ |cc, i| MIDIdef(("midimix_reverb_" ++ i.asString).asSymbol).free });
		midiMixDelayCCs.do({ |cc, i| MIDIdef(("midimix_delay_" ++ i.asString).asSymbol).free });
		MIDIdef(\midimix_wav_level).free;
		MIDIdef(\midimix_wav_filter).free;
		MIDIdef(\midimix_wav_reverb).free;
		MIDIdef(\midimix_wav_delay).free;
		MIDIdef(\groovebox_midi_learn_router).free;
		MIDIdef(\groovebox_midi_note_learn_router).free;
		MIDIdef(\groovebox_midi_note_off_router).free;
		OSCdef(\combined_groovebox_song_preset).free;
		delaySynth.free; reverbSynth.free; masterSynth.free;
		masterBus.free; delayBus.free; reverbBus.free;
	});

	redrawAll.();
	stopButton.background_(colors[\red]);
});
